  "query": "UPDATE channels\n             SET title = COALESCE($1, title),\n                 description = COALESCE($2, description),\n                 avatar_url = COALESCE($3, avatar_url),\n                 updated_at = NOW()\n             WHERE id = $4\n             RETURNING id, title, description, avatar_url, created_at, updated_at",
